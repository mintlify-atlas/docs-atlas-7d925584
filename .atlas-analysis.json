  "keyFeatures": [
    "Create secure short links with expiration control",
    "Upload files and generate download links",
    "Password protection for links",
    "Maximum view limit enforcement",
    "Manual link revocation",
    "Comprehensive access audit trail",
    "Real-time statistics and metrics",
    "Prometheus integration for monitoring"
  ],
  "publicApiSurface": [
    "POST /api/links - Create link for external URL",
    "POST /api/links/upload - Upload file and create link",
    "GET /l/{shortCode} - Resolve and access link",
    "DELETE /l/{shortCode} - Revoke link",
    "GET /api/stats/access/summary - Access summary statistics",
    "GET /api/stats/access/hourly - Hourly access distribution",
    "GET /api/stats/access/daily - Daily access counts",
    "GET /api/stats/access/failures - Failure distribution by type",
    "GET /api/stats/security/exceptions - Security exception hotspots",
    "GET /api/stats/links - Link status statistics",
    "GET /api/stats/links/top - Most accessed links",
    "GET /actuator/health - Health check endpoint",
    "GET /actuator/prometheus - Prometheus metrics"
  ]
